#!/usr/bin/env node
/**
 * symbols-audit — deterministic static audit for Symbols projects
 *
 * Usage:
 *   symbols-audit [path]                       # path defaults to ./symbols (STRICT BY DEFAULT)
 *   symbols-audit --json                       # machine output (findings + summary + mode)
 *   symbols-audit --allow-findings             # opt out of strict mode (exit 0 even with findings)
 *   symbols-audit --no-deep-fix                # opt out of deep-fix loop in strict mode
 *   symbols-audit --no-deep-framework-audit    # opt out of deep tracing into smbls/ source
 *
 * Mode flags (defaults shown):
 *   strict                 = !--allow-findings           # exit 1 if any findings
 *   deepFix                = strict && !--no-deep-fix    # agent must NOT stop at first blocker
 *   deepFrameworkAudit     = strict && !--no-deep-framework-audit
 *                                                        # trace ambiguous/framework findings into smbls/
 *
 * Exit codes:
 *   0 — clean (no open findings) OR --allow-findings was passed
 *   1 — open findings present (strict mode is the default)
 *   2 — invalid args / project path not found
 *
 * Output:
 *   audit/findings.json                  # full findings list with origin field (project|framework|shared)
 *   audit/before.snapshot.json           # baseline metrics (first run only)
 *   audit/symbols_audit_results.md       # PROJECT findings + resolutions (agent appends)
 *   audit/framework_audit_results.md     # FRAMEWORK bugs + repro + hypothesis (agent appends)
 *   audit/runs/<iso>.log                 # per-run log
 *   stdout                               # human summary + next-steps message (unless --json)
 *
 * Origin classification (initial heuristic, agent may reclassify in Phase 2):
 *   project   — file lives in user's symbols/ directory
 *   framework — file lives in node_modules/
 *   shared    — file lives in .symbols_local/ or shared-libraries/
 *
 * Rule regex patterns mirror symbols_mcp/server.py to keep CI behavior matching
 * what Claude sees from `audit_component`.
 *
 * NEVER edits project files. Findings are read-only output for downstream tools.
 * The AGENT (following AUDIT.md playbook) does the fixing, ASK-USER prompts,
 * and writes the markdown reports above.
 */

'use strict'

const fs = require('node:fs')
const path = require('node:path')
const crypto = require('node:crypto')

// -------- args --------

const args = process.argv.slice(2)
const flagJson = args.includes('--json')
// Strict is the default. --allow-findings opts out (returns 0 even with findings).
// --strict accepted as a no-op for back-compat.
const flagAllowFindings = args.includes('--allow-findings') || args.includes('--no-strict') || args.includes('--soft')
const flagStrict = !flagAllowFindings
// Deep modes default ON in strict mode. Opt out with --no-deep-fix / --no-deep-framework-audit.
// In non-strict mode (--allow-findings), they default OFF (the agent isn't iterating).
const flagDeepFix = flagStrict && !args.includes('--no-deep-fix')
const flagDeepFrameworkAudit = flagStrict && !args.includes('--no-deep-framework-audit')
const targetArg = args.find(a => !a.startsWith('--')) || './symbols'
const PROJECT_ROOT = path.resolve(targetArg)
const AUDIT_DIR = path.join(path.dirname(PROJECT_ROOT), 'audit')

// -------- helpers --------

const SEVERITY_ORDER = { critical: 0, structural: 1, systemic: 2, cosmetic: 3, info: 4 }

function shortHash(s) {
  return 'f_' + crypto.createHash('sha256').update(s).digest('hex').slice(0, 7)
}

function ensureDir(d) { fs.mkdirSync(d, { recursive: true }) }

function readUtf8(p) { try { return fs.readFileSync(p, 'utf-8') } catch { return null } }

function walk(dir, ext = '.js', out = []) {
  if (!fs.existsSync(dir)) return out
  for (const name of fs.readdirSync(dir)) {
    if (name.startsWith('.')) continue
    if (name === 'node_modules' || name === '.parcel-cache' || name === 'dist') continue
    const p = path.join(dir, name)
    const stat = fs.statSync(p)
    if (stat.isDirectory()) walk(p, ext, out)
    else if (p.endsWith(ext)) out.push(p)
  }
  return out
}

function lineOf(content, idx) {
  return content.slice(0, idx).split('\n').length
}

function rel(p) {
  return path.relative(PROJECT_ROOT, p) || path.basename(p)
}

// -------- rule patterns (mirrors symbols_mcp/server.py) --------

const FORBIDDEN_SYNTAX = [
  [/\bextend\s*:/g,                   'Rule 1',  'critical',  'forbidden-syntax', "use 'extends' (plural) instead of 'extend'"],
  [/\bchildExtend\s*:/g,              'Rule 1',  'critical',  'forbidden-syntax', "use 'childExtends' (plural)"],
  [/(^|\W)on\s*:\s*\{/g,              'Rule 1',  'critical',  'forbidden-syntax', "flatten event handlers as top-level onX (onClick/onInit), never on:{} wrapper"],
  [/(^|\W)props\s*:\s*\{(?!\s*\})/g,  'Rule 1',  'critical',  'forbidden-syntax', "flatten props directly on the component, never props:{} wrapper"],
  [/\bel\.props\.\w+/g,               'Rule 19', 'critical',  'flat-api',         "use flat el.X access (el.text, el.value), not el.props.X"],
  [/\bel\.on\.\w+/g,                  'Rule 19', 'critical',  'flat-api',         "use flat el.onX access (el.onClick), not el.on.event"],
  [/\(\s*\{\s*props\s*[,}]/g,         'Rule 19', 'critical',  'flat-api',         'reactive prop signature must be (el, s), never destructure ({ props })'],
  [/\(\s*\{\s*state\s*[,}]/g,         'Rule 19', 'critical',  'flat-api',         'reactive prop signature must be (el, s), never destructure ({ state })'],
  [/\(\s*\{\s*key\s*,\s*state/g,      'Rule 19', 'critical',  'flat-api',         'reactive prop signature must be (el, s), derive key via el.key'],
]

const HARDCODED_VALUES = [
  [/\b(?:padding|margin|gap|width|height|fontSize|borderRadius|minWidth|maxWidth|minHeight|maxHeight|top|left|right|bottom|letterSpacing|lineHeight|borderWidth|outlineWidth|aspectRatio)\s*:\s*['"]?\d+(?:\.\d+)?(?:px|rem)\b/g,
   'Rule 28', 'critical', 'design-tokens', 'use design-system spacing token (A, B, C, ...) instead of raw px/rem'],
  [/\b(?:color|background|backgroundColor|borderColor|fill|stroke|borderTopColor|borderBottomColor|borderLeftColor|borderRightColor)\s*:\s*['"]#[0-9a-fA-F]{3,8}/g,
   'Rule 27', 'critical', 'design-tokens', 'use design-system color token instead of hex'],
  [/\b(?:color|background|backgroundColor|borderColor|fill|stroke)\s*:\s*['"]rgb/g,
   'Rule 27', 'critical', 'design-tokens', 'use design-system color token instead of rgb()'],
  [/\b(?:color|background|backgroundColor|borderColor|fill|stroke)\s*:\s*['"]hsl/g,
   'Rule 27', 'critical', 'design-tokens', 'use design-system color token instead of hsl()'],
]

const MODERN_STACK_BYPASS = [
  [/\bwindow\.fetch\b/g,                                                        'Rule 47', 'critical', 'fetch',    'use declarative fetch: prop (@symbo.ls/fetch) or wrap in functions/ + el.call'],
  [/\baxios\s*\.\s*\w+\s*\(/g,                                                  'Rule 47', 'critical', 'fetch',    'use declarative fetch: prop instead of axios'],
  [/\$\.ajax\s*\(/g,                                                            'Rule 47', 'critical', 'fetch',    'use declarative fetch: prop instead of jQuery ajax'],
  [/\bdocument\.title\s*=/g,                                                    'Rule 49', 'critical', 'helmet',   'use metadata: { title } via @symbo.ls/helmet, never document.title'],
  [/\bdocument\.head\.append/g,                                                 'Rule 49', 'critical', 'helmet',   'use @symbo.ls/helmet metadata, never inject into document.head'],
  [/\bdocument\.documentElement\.setAttribute\s*\(\s*['"]data-theme/g,          'Rule 50', 'critical', 'theme',    "use changeGlobalTheme() from 'smbls', never write data-theme directly"],
  [/\bmatchMedia\s*\(\s*['"]\(prefers-color-scheme/g,                           'Rule 50', 'critical', 'theme',    'framework owns theme resolution; use @dark/@light CSS blocks, never read prefers-color-scheme manually'],
  [/\bglobalTheme\s*:\s*['"](?:dark|light)['"]/g,                               'Rule 50', 'critical', 'theme',    'never store globalTheme in root state; theme is a context-level concern'],
  [/\bwindow\.location\.href\s*=/g,                                             'Rule 42', 'critical', 'router',   'use el.router(path, el.getRoot()), never window.location'],
  [/\bwindow\.location\.assign\b/g,                                             'Rule 42', 'critical', 'router',   'use el.router(path, el.getRoot()), never window.location.assign'],
  [/\bwindow\.location\.replace\b/g,                                            'Rule 42', 'critical', 'router',   'use el.router(path, el.getRoot()), never window.location.replace'],
  [/\bel\.call\(\s*['"](?:t|tr|i18n|__t|_t)['"]/g,                              'Rule 48', 'critical', 'polyglot', "those polyglot functions don't exist — only `polyglot` is registered. Use el.call('polyglot', 'key') or '{{ key | polyglot }}' template"],
  [/\bxmlHttpRequest\b|\bXMLHttpRequest\b/g,                                    'Rule 47', 'critical', 'fetch',    'use declarative fetch: prop or el.getDB() — never raw XMLHttpRequest'],
]

const DOM_BANS = [
  [/\bdocument\.createElement\b/g,                            'Rule 30', 'critical', 'dom-bans',     'use DOMQL declarative children'],
  [/\bdocument\.querySelector\b/g,                            'Rule 40', 'critical', 'dom-bans',     "use el.lookdown('Key') / el.lookup('Key')"],
  [/\bdocument\.getElementById\b/g,                           'Rule 40', 'critical', 'dom-bans',     "use el.lookdown('Key')"],
  [/\bdocument\.querySelectorAll\b/g,                         'Rule 40', 'critical', 'dom-bans',     "use el.lookdownAll('Key')"],
  [/\bel\.appendChild\b|\.appendChild\s*\(/g,                 'Rule 30', 'critical', 'dom-bans',     'compose children declaratively; never appendChild'],
  [/\.removeChild\s*\(/g,                                     'Rule 30', 'critical', 'dom-bans',     'use if: prop to conditionally render'],
  [/\.insertBefore\s*\(/g,                                    'Rule 30', 'critical', 'dom-bans',     'use children array ordering'],
  [/\.classList\.(?:add|remove|toggle)\s*\(/g,                'Rule 30', 'critical', 'dom-bans',     "use isX + '.isX' pattern or class: { name: bool }"],
  [/\.innerHTML\s*=/g,                                        'Rule 30', 'critical', 'dom-bans',     'use text: or html: prop'],
  [/\.setAttribute\s*\(/g,                                    'Rule 30', 'critical', 'dom-bans',     'set attributes at the element root via flat props'],
  [/\.removeAttribute\s*\(/g,                                 'Rule 30', 'critical', 'dom-bans',     'return null/undefined from a prop function to remove the attribute'],
  [/\.addEventListener\s*\(/g,                                'Rule 30', 'critical', 'dom-bans',     'use flat onX event handlers'],
  [/\bel\.node\.style\.\w+\s*=/g,                             'Rule 39', 'critical', 'dom-bans',     'use DOMQL CSS-in-props (reading el.node is fine, writing is not)'],
  [/\bel\.node\.value\s*=/g,                                  'Rule 39', 'critical', 'dom-bans',     'use the value: prop'],
  [/\bel\.node\.textContent\s*=/g,                            'Rule 39', 'critical', 'dom-bans',     'use the text: prop'],
  [/\bel\.node\.innerHTML\s*=/g,                              'Rule 39', 'critical', 'dom-bans',     'use the html: prop'],
  [/\bparentNode\b|\bchildNodes\b/g,                          'Rule 32', 'systemic', 'dom-bans',     'use DOMQL tree methods (el.parent, el.lookdown)'],
  [/\bnextSibling\b|\bpreviousSibling\b/g,                    'Rule 32', 'systemic', 'dom-bans',     'use DOMQL siblings: el.nextElement(), el.previousElement()'],
]

const STRUCTURAL = [
  [/\bextends\s*:\s*(?!['"\[])\w+/g,                          'Rule 10', 'structural', 'reusability', 'extends must be a quoted string, not a variable reference'],
  [/\bchildExtends\s*:\s*\{/g,                                'Rule 10', 'structural', 'reusability', 'childExtends must be a quoted string, not an inline object — register as a named component'],
  [/\bextends\s*:\s*['"]Flex['"]/g,                           'Rule 26', 'systemic',   'flat-api',    "drop extends: 'Flex' — naming the key Flex: {} auto-applies the atom; or use flow:/align: directly"],
  [/\bextends\s*:\s*['"]Box['"]/g,                            'Rule 26', 'systemic',   'flat-api',    "drop extends: 'Box' — every element is already a Box"],
  [/\bextends\s*:\s*['"]Text['"]/g,                           'Rule 26', 'systemic',   'flat-api',    "drop extends: 'Text' — any element with text: is already Text"],
  [/^\s+([A-Z][a-zA-Z0-9_]*)\s*:\s*\{[^}]*\bextends\s*:\s*['"]\1['"]/gm,
                                                              'Rule 6',  'structural', 'reusability', "auto-extend by key — `Header: { extends: 'Navbar' }` should usually be `Navbar: {}`. Rename the wrapper key to the component name and drop `extends`. Multi-instance? `Navbar_1`, `Navbar_2` (auto-extends from the part before `_`). Keep `extends` only when the wrapper carries genuinely distinct semantic meaning, needs multi-base composition, or chains a nested-child reference (Rule 6)"],
]

// CRITICAL Rule 62 — html: '<svg ...>' for icons is banned.
const ICON_BANS = [
  [/\bhtml\s*:\s*['"`]\s*<svg\b/g,                            'Rule 62', 'critical', 'icons', "html: '<svg ...>' for rendering icons is BANNED — use Icon component referencing designSystem.icons by name (Rule 29/62). Inline SVG via html: bypasses the design system, breaks theme color resolution, breaks SSR, breaks brender hydration."],
  [/\btag\s*:\s*['"]svg['"]/g,                                'Rule 62', 'critical', 'icons', "tag: 'svg' inline component for an icon is BANNED — use Icon component + designSystem.icons (Rule 29/62)."],
  [/\btag\s*:\s*['"]path['"]/g,                               'Rule 62', 'critical', 'icons', "tag: 'path' inline component is BANNED — store the SVG path data in designSystem/icons and reference by name via the Icon component (Rule 29/62)."],
  [/\bextends\s*:\s*['"]Svg['"][^}]*html\s*:/g,               'Rule 62', 'critical', 'icons', "extends: 'Svg' with html: SVG markup is BANNED for icons — use Icon component + designSystem.icons (Rule 29/62). Svg is only for decorative/structural backgrounds, NOT icons."],
]

const POLYGLOT_HINTS = [
  // Hardcoded English placeholder/title heuristic — flag, don't fail
  [/placeholder\s*:\s*['"][A-Z][a-z]+(?:\s+[a-z]+)+['"]/g,    'Rule 48', 'systemic', 'polyglot',  'placeholder appears hardcoded — wrap in {{ key | polyglot }} or el.call(\'polyglot\', \'key\')'],
  [/text\s*:\s*['"][A-Z][a-z]+(?:\s+[a-z]+){2,}['"]/g,         'Rule 48', 'systemic', 'polyglot',  'text appears to be a hardcoded English sentence — use polyglot template'],
]

const ALL_RULES = [
  ...FORBIDDEN_SYNTAX,
  ...HARDCODED_VALUES,
  ...MODERN_STACK_BYPASS,
  ...DOM_BANS,
  ...STRUCTURAL,
  ...ICON_BANS,
  ...POLYGLOT_HINTS,
]

// -------- file-system structural checks --------

function checkFrankDiscovery(symbolsDir, findings) {
  if (!fs.existsSync(symbolsDir)) return
  const FRANK_SLOTS = new Set([
    'state.js', 'dependencies.js', 'sharedLibraries.js', 'config.js', 'cases.js', 'lang.js',
    'globalScope.js', 'app.js', 'index.js', 'symbols.json', 'vars.js'
  ])
  const FRANK_DIRS = new Set([
    'components', 'pages', 'functions', 'methods', 'snippets', 'designSystem', 'files', 'state'
  ])
  // FB-2: bundler outputs and static-asset directories are not frank discovery
  // slots, but they are required for the project to build/serve. Whitelisted.
  const BUILD_DIRS = new Set([
    'dist', '.cache', '.parcel-cache', 'assets', 'node_modules', 'audit'
  ])
  for (const name of fs.readdirSync(symbolsDir)) {
    const p = path.join(symbolsDir, name)
    if (!fs.statSync(p).isDirectory()) continue
    if (FRANK_DIRS.has(name)) continue
    if (BUILD_DIRS.has(name)) continue
    if (name.startsWith('.')) continue
    findings.push(makeFinding({
      file: rel(p),
      line: 1,
      rule: 'Rule 58',
      severity: 'structural',
      category: 'frank',
      snippet: `directory '${name}/'`,
      suggested_fix: `frank only discovers ${[...FRANK_DIRS].join('/')} folders; '${name}/' contents are stripped from the published JSON. Move loadable code into one of the standard slots, or import it from one of them.`,
    }))
  }
}

function checkComponentsIndexExportStar(symbolsDir, findings) {
  const indexFile = path.join(symbolsDir, 'components', 'index.js')
  const content = readUtf8(indexFile)
  if (!content) return
  const m = /export\s+\*\s+as\s+\w+\s+from/.exec(content)
  if (m) {
    findings.push(makeFinding({
      file: rel(indexFile),
      line: lineOf(content, m.index),
      rule: 'Rule 3',
      severity: 'critical',
      category: 'structure',
      snippet: m[0],
      suggested_fix: "use `export * from './X.js'` (no `as` wrapper) — namespace exports break component registry resolution",
    }))
  }
}

function checkPagesExtendsPage(symbolsDir, findings) {
  const pagesDir = path.join(symbolsDir, 'pages')
  if (!fs.existsSync(pagesDir)) return

  // FB-5: a page satisfies Rule 4 if 'Page' appears in the extends chain
  // — directly (`extends: 'Page'`), in an array (`extends: ['Page', X]`),
  // or transitively via a layout component that itself extends Page.
  // Build a transitive lookup from the components/ directory so we can
  // resolve chains like AdminLayout extends 'Page' → page extends 'AdminLayout'.
  const componentsDir = path.join(symbolsDir, 'components')
  const extendsChain = new Map() // ComponentName -> base it extends (string|null)
  if (fs.existsSync(componentsDir)) {
    for (const f of fs.readdirSync(componentsDir)) {
      if (!f.endsWith('.js') || f === 'index.js') continue
      const c = readUtf8(path.join(componentsDir, f))
      if (!c) continue
      const name = f.replace(/\.js$/, '')
      // Match the FIRST extends declaration in the file (the component's own).
      // Both single-string and first item of array form.
      const m = /extends\s*:\s*(?:['"]([A-Z][\w]*)['"]|\[\s*['"]([A-Z][\w]*)['"])/m.exec(c)
      extendsChain.set(name, (m && (m[1] || m[2])) || null)
    }
  }
  function reachesPage (componentName, seen = new Set()) {
    if (componentName === 'Page') return true
    if (!componentName || seen.has(componentName)) return false
    seen.add(componentName)
    const base = extendsChain.get(componentName)
    return base ? reachesPage(base, seen) : false
  }

  for (const f of fs.readdirSync(pagesDir)) {
    if (!f.endsWith('.js') || f === 'index.js') continue
    const p = path.join(pagesDir, f)
    const content = readUtf8(p)
    if (!content) continue

    // 1. Direct: `extends: 'Page'`
    if (/extends\s*:\s*['"]Page['"]/.test(content)) continue
    // 2. Array form: `extends: ['Page', ...]` — Page anywhere in the array
    if (/extends\s*:\s*\[\s*[^\]]*['"]Page['"]/.test(content)) continue
    // 3. Transitive: ANY `extends:` in the file where the named base
    //    transitively extends 'Page' satisfies the rule. Covers factory
    //    patterns (`const myPage = (…) => ({ extends: 'AdminLayout', … })`)
    //    where multiple page exports share one factory.
    const allExtendsRe = /\bextends\s*:\s*(?:['"]([A-Z][\w]*)['"]|\[\s*['"]([A-Z][\w]*)['"])/g
    let satisfied = false
    let em
    while ((em = allExtendsRe.exec(content)) !== null) {
      const base = em[1] || em[2]
      if (reachesPage(base)) { satisfied = true; break }
    }
    if (satisfied) continue

    findings.push(makeFinding({
      file: rel(p),
      line: 1,
      rule: 'Rule 4',
      severity: 'structural',
      category: 'structure',
      snippet: `page ${f} doesn't extend 'Page'`,
      suggested_fix: "every page must extend 'Page' (directly, via array form `extends: ['Page', X]`, or transitively through a layout that itself extends 'Page')",
    }))
  }
}

function checkLowercaseChildKeys(content, file, findings) {
  // FB-4: design-system modules (color.js, theme.js, typography.js, etc.)
  // are dictionaries of values, not component trees. Lowercase keys there
  // are the convention. Skip Rule 6 entirely for designSystem/.
  if (/[\\/]designSystem[\\/]/.test(file)) return

  // Match `  fooBar: {` style — leading whitespace, lowercase first char, followed by `:`, followed by `{`
  // Skip known-OK keys (CSS props), only flag clear violations like h1, nav, form, hgroup, group, div
  const KNOWN_NEVER_RENDER = new Set(['h1','h2','h3','h4','h5','h6','nav','form','hgroup','group','div','section','article','header','footer','main','aside','span','p','button','input','select','textarea','img','video','iframe','svg','table','tr','td','th','ul','ol','li','a'])
  const re = /^\s+([a-z][a-zA-Z0-9_]*)\s*:\s*\{/gm
  let m
  while ((m = re.exec(content)) !== null) {
    if (!KNOWN_NEVER_RENDER.has(m[1])) continue
    findings.push(makeFinding({
      file: rel(file),
      line: lineOf(content, m.index),
      rule: 'Rule 6',
      severity: 'critical',
      category: 'structure',
      snippet: m[0].trim(),
      suggested_fix: `lowercase keys NEVER render. Rename '${m[1]}:' to '${m[1].charAt(0).toUpperCase() + m[1].slice(1)}:' (PascalCase) — the framework auto-detects the HTML tag from the key.`,
    }))
  }
}

function checkImportsBetweenFiles(content, file, findings) {
  // Allowed: index.js files (re-export hubs), context.js + app.js + dependencies.js + sharedLibraries.js (aggregation/wiring), state/index.js, designSystem/index.js
  // Disallowed: imports from sibling component/page/function files
  const fname = path.basename(file)
  const ALLOW_IMPORTS = new Set([
    'index.js',          // every */index.js is a re-export hub
    'context.js',        // aggregates state + designSystem + components + ... into context
    'app.js',            // entry — may import context
    'dependencies.js',   // declares external deps
    'sharedLibraries.js',// declares shared lib references
  ])
  if (ALLOW_IMPORTS.has(fname)) return
  // Skip dependencies.js anywhere it lives
  if (file.endsWith('/symbols.json')) return
  const re = /^\s*import\s+.*\bfrom\s+['"](\.\.?\/[^'"]+)['"]/gm
  let m
  while ((m = re.exec(content)) !== null) {
    findings.push(makeFinding({
      file: rel(file),
      line: lineOf(content, m.index),
      rule: 'Rule 2',
      severity: 'structural',
      category: 'structure',
      snippet: m[0].trim().slice(0, 120),
      suggested_fix: `imports between project files are forbidden (only index.js / context.js / app.js / dependencies.js / sharedLibraries.js may import siblings). Reference components by string key (extends: 'Name') and call functions via el.call('fnName', ...).`,
    }))
  }
}

// -------- finding helpers --------

// Heuristic origin classifier. The CLI scans the user's symbols/ dir, so by
// default findings ORIGINATE in the project. Some paths (node_modules, shared
// libs, .symbols_local) are clearly framework / shared-library territory.
// Anything the agent later proves is a framework gap (after 3 fix attempts
// fail) gets bumped to origin='framework' + status='framework_bug' during
// Phase 2 of the playbook.
function classifyOrigin(file) {
  if (!file) return 'project'
  const f = file.replace(/\\/g, '/')
  if (f.includes('/node_modules/') || f.includes('node_modules/')) return 'framework'
  if (f.includes('/.symbols_local/') || f.startsWith('.symbols_local/')) return 'shared'
  if (f.includes('/shared-libraries/') || f.includes('/sharedLibraries/')) return 'shared'
  return 'project'
}

function makeFinding({ file, line, rule, severity, category, snippet, suggested_fix }) {
  const id = shortHash(`${file}:${line}:${rule}:${snippet}`)
  return {
    id,
    file: file.replace(/\\/g, '/'),
    line,
    rule,
    severity,
    category,
    origin: classifyOrigin(file),
    snippet,
    suggested_fix,
    status: 'open',
    discovered_at: new Date().toISOString(),
    resolved_at: null,
    attempts: 0,
    notes: [],
  }
}

// -------- snapshot --------

function snapshot(symbolsDir) {
  const files = walk(symbolsDir, '.js')
  const components = files.filter(f => f.includes('/components/') && !f.endsWith('/index.js'))
  const pages = files.filter(f => f.includes('/pages/') && !f.endsWith('/index.js'))
  let lineCount = 0
  for (const f of files) lineCount += (readUtf8(f) || '').split('\n').length
  return {
    timestamp: new Date().toISOString(),
    fileCount: files.length,
    componentCount: components.length,
    pageCount: pages.length,
    lineCount,
  }
}

// -------- main --------

function run() {
  if (!fs.existsSync(PROJECT_ROOT)) {
    console.error(`✗ Project path does not exist: ${PROJECT_ROOT}`)
    process.exit(2)
  }

  const symbolsDir = PROJECT_ROOT
  const auditDir = AUDIT_DIR
  ensureDir(auditDir)
  ensureDir(path.join(auditDir, 'runs'))

  const startTime = Date.now()
  const isoNow = new Date().toISOString().replace(/[:.]/g, '-')
  const logPath = path.join(auditDir, 'runs', `${isoNow}.log`)
  const logLines = []
  const log = (...a) => { const s = a.join(' '); logLines.push(s); if (!flagJson) console.error(s) }

  log(`# symbols-audit run @ ${new Date().toISOString()}`)
  log(`Project: ${PROJECT_ROOT}`)
  log('')

  // Baseline snapshot (only on first run)
  const beforePath = path.join(auditDir, 'before.snapshot.json')
  if (!fs.existsSync(beforePath)) {
    const snap = snapshot(symbolsDir)
    fs.writeFileSync(beforePath, JSON.stringify(snap, null, 2))
    log(`✓ Baseline snapshot written to ${rel(beforePath)}`)
  }

  const findings = []

  // 1. Walk all .js files and apply regex rules
  const allFiles = walk(symbolsDir, '.js')
  log(`Scanning ${allFiles.length} .js files...`)

  for (const f of allFiles) {
    const content = readUtf8(f)
    if (!content) continue
    // Skip the audit folder itself if we somehow recursed into it
    if (rel(f).startsWith('audit/') || rel(f).startsWith('../audit/')) continue
    // Skip designSystem/ — token DEFINITIONS may legitimately use raw values
    const isDesignSystem = /\/designSystem\//.test(f)
    // Skip pages/index.js for the import rule (allowed to import siblings)
    const isPagesIndex = /\/pages\/index\.js$/.test(f)
    // Skip */index.js for import rules (re-export hubs)
    const isHubIndex = /\/index\.js$/.test(f)

    // FB-1 (file-level): a single `@symbols allow-file <categories>` comment
    // anywhere in the first 50 lines whitelists those categories for the
    // entire file. Use `all` to whitelist everything. Use sparingly — this
    // is the right call for runtime bootstrap scripts that legitimately need
    // DOM APIs (e.g. injecting an importmap + module-script tag for an
    // async-loaded WebGL animation).
    const headPreview = content.split('\n').slice(0, 50).join('\n')
    const fileAllowRe = /@symbols\s+allow-file\s+([\w\s,-]+)/i
    const fileAllowMatch = fileAllowRe.exec(headPreview)
    const fileAllowed = new Set(
      fileAllowMatch ? fileAllowMatch[1].split(/[\s,]+/).map(s => s.trim().toLowerCase()).filter(Boolean) : []
    )

    for (const [pattern, rule, severity, category, hint] of ALL_RULES) {
      if (fileAllowed.has('all') || fileAllowed.has(category.toLowerCase())) continue
      // Reset regex (because of /g flag)
      const re = new RegExp(pattern.source, pattern.flags)
      let m
      while ((m = re.exec(content)) !== null) {
        // Skip token-definition files for hardcoded-value rules
        if (isDesignSystem && (category === 'design-tokens')) continue
        // Per-line allow-comment to escape rules. The marker
        // `// @symbols allow <category>` on the same line whitelists this
        // hit.
        const lineNo = lineOf(content, m.index)
        const lineStart = content.lastIndexOf('\n', m.index) + 1
        const lineEnd = content.indexOf('\n', m.index)
        const line = content.slice(lineStart, lineEnd === -1 ? content.length : lineEnd)
        const allowRe = new RegExp(`@symbols\\s+allow\\s+(?:${category}|all|${rule.replace(/\s+/g, '\\s+')})`, 'i')
        if (allowRe.test(line)) continue
        findings.push(makeFinding({
          file: rel(f),
          line: lineNo,
          rule, severity, category,
          snippet: m[0].slice(0, 120),
          suggested_fix: hint,
        }))
      }
    }

    // File-level structural checks
    checkLowercaseChildKeys(content, f, findings)
    checkImportsBetweenFiles(content, f, findings)   // self-filters allowed files
  }

  // 2. Project-level structural checks
  checkFrankDiscovery(symbolsDir, findings)
  checkComponentsIndexExportStar(symbolsDir, findings)
  checkPagesExtendsPage(symbolsDir, findings)

  // 3. Sort findings by severity
  findings.sort((a, b) => SEVERITY_ORDER[a.severity] - SEVERITY_ORDER[b.severity] || a.file.localeCompare(b.file) || a.line - b.line)

  // 4. Write findings.json (merge with existing if present, preserving status)
  const findingsPath = path.join(auditDir, 'findings.json')
  let existing = { items: [] }
  if (fs.existsSync(findingsPath)) {
    try { existing = JSON.parse(fs.readFileSync(findingsPath, 'utf-8')) } catch {}
  }
  const existingById = new Map((existing.items || []).map(it => [it.id, it]))
  const merged = []
  for (const f of findings) {
    const prior = existingById.get(f.id)
    if (prior) {
      // Preserve status/resolved_at/attempts/notes from prior run
      merged.push({ ...f, status: prior.status, resolved_at: prior.resolved_at, attempts: prior.attempts, notes: prior.notes })
      existingById.delete(f.id)
    } else {
      merged.push(f)
    }
  }
  // Findings present in prior run but not in this run = resolved (the violation is gone)
  for (const stale of existingById.values()) {
    if (stale.status !== 'resolved' && stale.status !== 'framework_bug') {
      stale.status = 'resolved'
      stale.resolved_at = stale.resolved_at || new Date().toISOString()
    }
    merged.push(stale)
  }
  fs.writeFileSync(findingsPath, JSON.stringify({ $schema: 'symbols-mcp findings v1', items: merged }, null, 2))

  // 5. Summary
  const open = merged.filter(f => f.status === 'open' || f.status === 'in_progress')
  const byCategory = open.reduce((acc, f) => { acc[f.category] = (acc[f.category] || 0) + 1; return acc }, {})
  const bySeverity = open.reduce((acc, f) => { acc[f.severity] = (acc[f.severity] || 0) + 1; return acc }, {})

  log('')
  log(`Findings: ${open.length} open / ${merged.length} total (${merged.filter(f => f.status === 'resolved').length} resolved, ${merged.filter(f => f.status === 'framework_bug').length} framework bugs)`)
  if (open.length) {
    log('')
    log('By severity:')
    for (const [sev, n] of Object.entries(bySeverity).sort((a, b) => SEVERITY_ORDER[a[0]] - SEVERITY_ORDER[b[0]])) {
      log(`  ${sev.padEnd(12)} ${n}`)
    }
    log('')
    log('By category:')
    for (const [cat, n] of Object.entries(byCategory).sort((a, b) => b[1] - a[1])) {
      log(`  ${cat.padEnd(20)} ${n}`)
    }
    log('')
    log('Top 10 findings:')
    for (const f of open.slice(0, 10)) {
      log(`  [${f.severity}] ${f.file}:${f.line}  ${f.rule}  ${f.snippet}`)
      log(`               → ${f.suggested_fix}`)
    }
    if (open.length > 10) log(`  ... and ${open.length - 10} more (see audit/findings.json)`)
  } else {
    log('✓ No open findings')
  }

  // 6. Write the two report skeletons (idempotent — agents append to them)
  const projPath = path.join(auditDir, 'symbols_audit_results.md')
  const fwPath = path.join(auditDir, 'framework_audit_results.md')
  if (!fs.existsSync(projPath)) {
    fs.writeFileSync(projPath, [
      '---',
      'kind: project-audit-results',
      `created_at: ${new Date().toISOString()}`,
      '---',
      '',
      '# Symbols project audit — findings & resolutions',
      '',
      'This file records project-level findings (issues in YOUR code) and how each was',
      'resolved. The agent following the AUDIT.md playbook appends an entry per finding',
      'as it works through Phase 2. Framework-originated bugs (rule is correct but the',
      'framework breaks when the fix is applied) get logged separately to',
      '`framework_audit_results.md`.',
      '',
      '## Strict-mode contract',
      '',
      'In strict mode (default), every finding must reach one of:',
      '- `resolved` — fix applied, re-audit confirms violation gone',
      '- `framework_bug` — moved to framework_audit_results.md after 3 failed fix attempts',
      '- `ask_user` — needs explicit user input (creds, key, design decision); agent surfaces a `🟢 ASK USER` block',
      '',
      'No finding stays `open` at the end of strict-mode run.',
      '',
      '## Resolutions',
      '',
      '_(populated by the agent during Phase 2 — one entry per finding fixed)_',
      '',
    ].join('\n'))
    log(`✓ Created template: ${rel(projPath)}`)
  }
  if (!fs.existsSync(fwPath)) {
    fs.writeFileSync(fwPath, [
      '---',
      'kind: framework-audit-results',
      `created_at: ${new Date().toISOString()}`,
      `deep_framework_audit: ${flagDeepFrameworkAudit}`,
      '---',
      '',
      '# Symbols FRAMEWORK audit — bugs originating in smbls/, plugins, or shared libs',
      '',
      'This file is the queue of findings the agent could NOT resolve at the project',
      'level — applying the recommended fix breaks the framework or shared library.',
      'Each entry must clearly explain the issue so the framework team can debug it.',
      '',
      '## Per-bug template',
      '',
      'For every framework_bug finding, write:',
      '',
      '```markdown',
      '### [<rule>] <one-line summary>',
      '',
      '- **Finding ID:** `<id from findings.json>`',
      '- **Origin file (project):** `<path>:<line>`',
      '- **Suspected framework file:** `<path in smbls/, plugins/, or shared lib>`',
      '- **What the rule says should work:** <quote from RULES.md>',
      '- **What actually happens when you apply the fix:** <error / silent failure / wrong render>',
      '- **Repro:**',
      '  1. <step>',
      '  2. <step>',
      '- **Stack / log evidence:** ```<stack>```',
      '- **Hypothesis (deep audit):** <what the agent traced into framework source>',
      '- **Suggested framework patch:** <if known>',
      '```',
      '',
      '## Deep framework audit',
      '',
      `- Mode: \`--deep-framework-audit=${flagDeepFrameworkAudit}\` (default true in strict mode).`,
      '- When ON, the agent traces every ambiguous/framework finding into smbls/ source',
      '  via Read + Grep, identifies the responsible function/file, and writes a',
      '  hypothesis under "Suggested framework patch". Agents in stdio mode with',
      '  filesystem access run this automatically; agents in SSE/HTTPS mode surface',
      '  the trace command to the user.',
      '',
      '## Bugs',
      '',
      '_(populated by the agent during Phase 2 + Phase 4 deep-framework loop)_',
      '',
    ].join('\n'))
    log(`✓ Created template: ${rel(fwPath)}`)
  }

  log('')
  log(`Mode: strict=${flagStrict}, deep-fix=${flagDeepFix}, deep-framework-audit=${flagDeepFrameworkAudit}`)
  log(`Run took ${((Date.now() - startTime) / 1000).toFixed(2)}s`)
  log(`Wrote: ${rel(findingsPath)}`)
  log(`       ${rel(projPath)}  (project audit results — agent appends)`)
  log(`       ${rel(fwPath)}  (framework audit results — agent appends)`)
  log(`Log:   ${rel(logPath)}`)

  // Origin breakdown for the agent's planning
  const byOrigin = open.reduce((acc, f) => { const o = f.origin || 'project'; acc[o] = (acc[o] || 0) + 1; return acc }, {})
  if (open.length) {
    log('')
    log('By origin (initial classification — Phase 2 may reclassify):')
    for (const [o, n] of Object.entries(byOrigin)) log(`  ${o.padEnd(12)} ${n}`)
  }

  // 7. Next-steps message — guides the agent on what mode to enter
  if (flagStrict && open.length > 0) {
    log('')
    log('Next steps (strict mode):')
    log('  1. Phase 2: fix every `open` finding — re-run this CLI after each fix to verify.')
    log('  2. After 3 failed fix attempts, move the finding to framework_audit_results.md')
    log('     with full repro + framework hypothesis (see template).')
    if (flagDeepFix) {
      log('  3. --deep-fix is ON: do NOT stop at first blocker. Surface a `🟢 ASK USER`')
      log('     block for missing creds / project keys / design decisions, then continue.')
    }
    if (flagDeepFrameworkAudit) {
      log('  4. --deep-framework-audit is ON: trace ambiguous/framework findings into smbls/')
      log('     source via Read + Grep; write hypothesis into framework_audit_results.md.')
    }
    log('  5. After fix loop: Phase 3 (build / publish / chrome-mcp UI tests). Phase 5 report.')
  }

  // Write log file
  fs.writeFileSync(logPath, logLines.join('\n') + '\n')

  // 8. Output
  if (flagJson) {
    process.stdout.write(JSON.stringify({
      items: merged,
      summary: { open: open.length, total: merged.length, byCategory, bySeverity, byOrigin },
      mode: { strict: flagStrict, deepFix: flagDeepFix, deepFrameworkAudit: flagDeepFrameworkAudit },
    }, null, 2))
  }

  // 9. Exit code
  if (flagStrict && open.length > 0) {
    process.exit(1)
  }
  process.exit(0)
}

run()
